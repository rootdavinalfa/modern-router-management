{
  "name": "modern-router-management",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "dev:web": "turbo run web#dev",
    "dev:api": "turbo run api#dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "clean": "turbo run clean && rm -rf node_modules && rm -rf .turbo",
    "clean:cache": "rm -rf .turbo && rm -rf **/.turbo",
    "build:types": "turbo run @modern-router-management/types#build",
    "build:drivers": "turbo run @modern-router-management/drivers#build",
    "build:ui": "turbo run @modern-router-management/ui#build",
    "build:api": "turbo run api#build",
    "build:web": "turbo run web#build"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.8.12",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
