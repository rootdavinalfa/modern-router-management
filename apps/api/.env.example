# Database Configuration
# Options: sqlite or postgres
DB_ENGINE=sqlite

# PostgreSQL connection string (required if DB_ENGINE=postgres)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=

# SQLite database file path (used if DB_ENGINE=sqlite)
SQLITE_PATH=./data/dev.sqlite

# Encryption key for router credentials (base64 encoded, 32 bytes)
# Generate with: openssl rand -base64 32
ROUTER_CREDENTIALS_KEY=

# API server port
PORT=3001
